{
  "family": "fastapi-ecs-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "ARM64"
  },
  "executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/fastapi-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/fastapi-ecs-task-role",
  "volumes": [
    {
      "name": "tmp"
    }
  ],
  "containerDefinitions": [
    {
      "name": "fastapi-ecs-container",
      "image": "PLACEHOLDER_REPLACED_AT_DEPLOY",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "INTERNAL_SERVICE_URL",
          "value": "http://internal-api:8001"
        },
        {
          "name": "SQS_QUEUE_URL",
          "value": "https://sqs.${AWS_REGION}.amazonaws.com/${AWS_ACCOUNT_ID}/fastapi-ecs-queue"
        },
        {
          "name": "AWS_REGION",
          "value": "${AWS_REGION}"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health').read()\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "linuxParameters": {
        "initProcessEnabled": true
      },
      "readonlyRootFilesystem": true,
      "mountPoints": [
        {
          "sourceVolume": "tmp",
          "containerPath": "/tmp",
          "readOnly": false
        }
      ],
      "stopTimeout": 30,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/fastapi-ecs",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
